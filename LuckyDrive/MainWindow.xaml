<Window x:Class="LuckyDrive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="LuckyDrive - 纯绿色多网盘卡片挂载器" Height="650" Width="1000" WindowStartupLocation="CenterScreen" Background="#F3F3F3">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" Grid.Column="0" Padding="25">
            <StackPanel>
                <TextBlock Text="添加网盘卡片" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="网盘自定义名称:" Margin="0,0,0,5" Foreground="#666666"/>
                <TextBox x:Name="TxtName" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5"/>

                <TextBlock Text="Lucky WebDAV URL (例如: 192.168.1.2:1234/dav):" Margin="0,0,0,5" Foreground="#666666"/>
                <TextBox x:Name="TxtUrl" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5"/>

                <TextBlock Text="用户账号 (没有可留空):" Margin="0,0,0,5" Foreground="#666666"/>
                <TextBox x:Name="TxtUser" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5"/>

                <TextBlock Text="访问密码 (没有可留空):" Margin="0,0,0,5" Foreground="#666666"/>
                <PasswordBox x:Name="TxtPass" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5"/>

                <TextBlock Text="选择挂载虚拟盘符:" Margin="0,0,0,5" Foreground="#666666"/>
                <ComboBox x:Name="ComboDrive" Height="35" Margin="0,0,0,20" VerticalContentAlignment="Center"/>

                <Button x:Name="BtnSave" Content="保存配置卡片" Height="40" Background="#0078D4" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="我的 Lucky 网盘群" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <ListBox x:Name="ListDrives" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ListDrives_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Width="540"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="250" Height="160" Background="White" CornerRadius="8" Margin="10" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#222222" TextTrimming="CharacterEllipsis"/>
                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#666666"/>
                                </StackPanel>

                                <Grid Grid.Row="2" VerticalAlignment="Bottom">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Content="{Binding ButtonText}" Background="{Binding ButtonBg}" Foreground="White" FontWeight="Bold" Height="32" BorderThickness="0" Click="BtnToggleMount_Click" Tag="{Binding Id}"/>
                                    <Button Grid.Column="1" Content="删除" Background="#F2F2F2" Foreground="#333333" Height="32" Width="50" Margin="10,0,0,0" BorderThickness="0" Click="BtnDelete_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
