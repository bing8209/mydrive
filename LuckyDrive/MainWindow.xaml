<Window x:Class="LuckyDrive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fw="clr-namespace:SourceChord.FluentWPF;assembly=FluentWPF"
        fw:AcrylicWindow.Enabled="True"
        fw:AcrylicWindow.AcrylicWindowStyle="NoIcon"
        Title="LuckyDrive - 零缓存轻量虚拟盘" Height="400" Width="550" 
        Background="#501E1E1E" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="LuckyDrive 存储挂载" FontSize="22" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="基于 WinFsp 内核 · 纯内存流式传输不伤固态" FontSize="12" Foreground="#A0FFFFFF" Margin="0,0,0,20"/>

            <Border Background="#20FFFFFF" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="地址:" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtUrl" Text="http://192.168.1.1:端口/dav" Padding="5" Background="#40000000" Foreground="White" BorderBrush="#40FFFFFF"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="用户名:" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtUser" Text="bing" Padding="5" Background="#40000000" Foreground="White" BorderBrush="#40FFFFFF"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="密码:" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="TxtPass" Padding="5" Background="#40000000" Foreground="White" BorderBrush="#40FFFFFF"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="挂载盘符:" Foreground="White" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ComboDrive" SelectedIndex="0" Width="60" HorizontalAlignment="Left" Padding="5">
                        <ComboBoxItem Content="Z:"/>
                        <ComboBoxItem Content="Y:"/>
                        <ComboBoxItem Content="X:"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Grid Margin="0,20,0,0">
                <TextBlock x:Name="LblStatus" Text="状态: 未连接" Foreground="#FFFFCC00" VerticalAlignment="Center" FontSize="14"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnConnect" Content="立即挂载" Width="100" Height="35" Background="#FF0078D4" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnConnect_Click"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
